NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=cabin-photos

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_long_random_password
COOKIE_SECRET=change_me_to_a_long_random_cookie_secret
SESSION_TTL_HOURS=12

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Необязательно: если пусто, секрет webhook детерминированно выводится из
# TELEGRAM_BOT_TOKEN и COOKIE_SECRET. Допустимы A-Z, a-z, 0-9, _ и -.
TELEGRAM_WEBHOOK_SECRET=
# Необязательно: защищённый Cloudflare Worker-ретранслятор для серверов,
# у которых нет стабильного доступа к api.telegram.org.
TELEGRAM_RELAY_URL=
TELEGRAM_RELAY_SECRET=

# Интервал синхронизации внешних iCal-календарей, минуты
EXTERNAL_CALENDAR_SYNC_MINUTES=30
# Для тестового запуска без Telegram/iCal фоновых задач
DISABLE_BACKGROUND_JOBS=false

